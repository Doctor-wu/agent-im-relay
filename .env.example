# Development-only convenience file for direct package runs.
# The distributed launcher should prefer ~/.agent-inbox/config.jsonl.

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
GUILD_IDS=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_PORT=3001

# Telegram Bot Token，从 @BotFather 创建 Bot 后获取，格式为 123456:ABC-DEF...
TELEGRAM_BOT_TOKEN=
# 允许使用 Bot 的 Telegram 用户 ID 白名单，逗号分隔（留空则允许所有人）
# 用户 ID 可通过 @userinfobot 查询，例如：123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=
# 单条消息最大字符数，Telegram 上限为 4096，建议留一点余量
TELEGRAM_MESSAGE_CHAR_LIMIT=4000

CLAUDE_MODEL=
AGENT_TIMEOUT_MS=600000
ARTIFACT_RETENTION_DAYS=14
ARTIFACT_MAX_SIZE_BYTES=8388608
STREAM_UPDATE_INTERVAL_MS=1000
DISCORD_MESSAGE_CHAR_LIMIT=1900
