{
  "name": "discord-claude-bridge",
  "version": "1.0.0",
  "description": "Discord bot that lets users interact with Claude Code directly in Discord threads",
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsdown": "^0.20.1",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
